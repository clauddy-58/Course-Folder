# Load necessary libraries
library(tidyverse)
library(ggrepel)
library(ggthemes)
library(scales)
library(plotly)
library(lattice)
library(GGally)
library(wooldridge)
library(gt)
# Prepare the data
df <- as_tibble(attend)
df %>%
head(10) %>% # Displaying first 10 rows
gt() %>%
tab_header(title = "Class Attendance Data", subtitle = "First 10 observations") %>%
tab_options(table.background.color = "lightgray") %>%
cols_label(termGPA = "Term GPA", priGPA = "Prior GPA") %>%
tab_style(style = cell_text(weight = "bold"), locations = cells_column_labels())
# Relabel soph variable
df_soph_relabeled <- df %>%
mutate(soph = case_when(soph == "1" ~ "Sophomore",
soph == "0" ~ "Non-Sophomore"),
soph = factor(soph))
# Print to confirm
print(df_soph_relabeled)
# Create Plot
ggplot2::ggplot(df_soph_relabeled, aes(x = priGPA, y = missed)) +
geom_point(color = "blue", size = 2) +
geom_smooth(method = "lm", color = "red") +
facet_wrap(~soph) +
theme_bw() +
labs(title = "Relationship between Prior GPA and Classes Missed",
x = "Prior GPA", y = "Classes Missed",
caption = "Moderator: Sophomore Status")
# Relabel soph variable
df_soph_relabeled <- df %>%
mutate(soph = case_when(soph == "1" ~ "Sophomore",
soph == "0" ~ "Non-Sophomore"),
soph = factor(soph))
# Print to confirm
print(df_soph_relabeled)
# Create Plot
ggplot2::ggplot(df_soph_relabeled, aes(x = priGPA, y = missed)) +
geom_point(color = "blue", size = 2) +
geom_smooth(method = "lm", color = "red") +
facet_wrap(~soph) +
theme_bw() +
labs(title = "Relationship between Prior GPA and Classes Missed",
x = "Prior GPA", y = "Classes Missed",
caption = "Moderator: Sophomore Status")
# 3.1 Distribution of ACT
ggplot(df_soph_relabeled, aes(x = factor(ACT))) + geom_bar()
# 3.2 Stacked, Dodged, and Faceted
# Stacked
ggplot(df_soph_relabeled, aes(x = factor(ACT), y = final, fill = soph)) + geom_col(position = "stack")
# Dodged
ggplot(df_soph_relabeled, aes(x = factor(ACT), y = final, fill = soph)) + geom_col(position = "dodge")
# Faceted
ggplot(df_soph_relabeled, aes(x = factor(ACT), y = final)) + geom_col() + facet_wrap(~soph)
df_soph_relabled_summarized <- df_soph_relabeled %>%
group_by(soph, ACT) %>%
summarise(final_avg = mean(final), n = n(), .groups = "drop")
# Use final_avg for Y-axis
ggplot(df_soph_relabled_summarized, aes(x = factor(ACT), y = final_avg, fill = soph)) +
geom_col(position = "dodge")
ggplot(df_soph_relabeled, aes(x = factor(ACT), y = final, fill = soph)) +
geom_boxplot(alpha = 0.6) +
geom_jitter(width = 0.2, alpha = 0.3)
df_frosh <- df %>% mutate(frosh = factor(frosh))
ggplot(df_frosh, aes(x = factor(ACT), y = attend)) +
geom_boxplot() +
facet_wrap(~frosh)
ggplot(df, aes(x = ACT, y = attend)) +
geom_point() +
geom_smooth(method = "lm") +
facet_wrap(~frosh)
vars <- df %>% select(attend, termGPA, priGPA, ACT, final, atndrte, hwrte)
ggpairs(vars)
plot_ex9 <- ggplot(df_soph_relabeled, aes(x = priGPA, y = termGPA, color = soph)) +
geom_point() +
geom_smooth(method = "lm")
print(plot_ex9)
# Interactive
ggplotly(plot_ex9)
# Save
ggsave("myplot.png", plot = plot_ex9)
